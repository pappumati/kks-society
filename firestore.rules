rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only signed-in staff/admin (created via the app's Settings tab
    // or the default admin) can read or write any society data.
    // There is no public-facing collection in this app, unlike the
    // library app's student self-registration flow.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
